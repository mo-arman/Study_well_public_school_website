# Copy this file to .env and fill in real values.
# See README section "ERP Backend Setup" for step-by-step instructions.

# Postgres connection string (from Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# A random secret used to sign login sessions. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Only needed in production, set automatically by Vercel usually — but
# it's safest to set it explicitly to your real domain once you have one.
# NEXTAUTH_URL="https://www.yourschooldomain.com"
